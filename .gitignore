# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large video files (>100MB GitHub limit)
public/hero-video.mp4

# RCU Confidential Brochures - NEVER push to remote
public/private/
scratch/

# Vendor NDAs, agreements, company profiles, rate cards - NEVER push to remote
SEM VENDOR DETAILS/

# Google Search Console exports - private business data, must never be committed
# (especially not inside public/, where it would be served on the live site)
public/saudieventmanagement.com-Performance-on-Search-*/
SEO/

# Local archive of unused files (kept on laptop, not deployed)
archive/
