generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Provided automatically by the Vercel ↔ Supabase integration.
  // Pooled connection (pgbouncer) — used by the app at runtime.
  url       = env("POSTGRES_PRISMA_URL")
  // Direct (non-pooled) connection — used by `prisma migrate` / `db push`.
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("admin") // admin, super_admin, editor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  company     String?
  status      String   @default("Active") // VIP, Active, Corporate, Lead
  notes       String?
  totalSpend  Float    @default(0)
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id           String   @id @default(uuid())
  title        String
  description  String?
  date         DateTime?
  location     String?
  type         String   @default("General") // Wedding, Corporate, Private, Culture
  status       String   @default("Inquiry") // Inquiry, Quoted, Booked, Completed, Cancelled
  timeline     String   @default("Planning") // Planning, Vendor Selection, Proposal, Confirmation, Execution, Completed
  guestCount   String?
  budget       String?
  client       Client?  @relation(fields: [clientId], references: [id])
  clientId     String?
  vendors      Vendor[] @relation("EventVendors")
  quotes       Quote[]
  media        MediaAsset[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vendor {
  id           String   @id @default(uuid())
  name         String
  category     String   // primary category (legacy single value, kept for existing UI)
  services     String?
  // ── PRIVATE CONTACT FIELDS — never expose on public routes/APIs/exports.
  //    Only /admin (requireAdmin-guarded) may read these. Matching results must
  //    use a select that excludes them. ──
  contactInfo  String?
  email        String?
  phone        String?
  whatsapp     String?
  contactPerson String?
  // ── end private fields ──
  city         String?
  portfolio    String?  // URL
  pricing      String?  // JSON string or description
  availability String?  // Available, Booked, Seasonal
  rating       Float    @default(5.0)
  // ── Vendor-system fields (2026-07 intake rollout) ──
  categories         String[] @default([]) // multi-category support
  regionCoverage     String[] @default([]) // cities/regions served
  yearsExperience    Int?
  certifications     String?
  rateCardSummary    String?
  rateCardFiles      String?  // file names, stored locally on founder's laptop (SEM VENDOR DETAILS/)
  portfolioFiles     String?  // file names / folder refs, stored locally
  meetingStatus      String   @default("Contacted") // Contacted, Meeting Scheduled, Met, Negotiating, Confirmed Partner, Not Proceeding
  agreementSigned    Boolean  @default(false)
  agreementDate      DateTime?
  verificationStatus String   @default("Pending") // Verified, Pending, Unverified
  internalRating     Int      @default(0) // 0 = unrated, 1-5 editable as projects complete
  preferred          Boolean  @default(false) // featured/preferred partner flag
  photoPermission    Boolean  @default(false) // written permission to showcase their photos
  notes        VendorNote[]
  events       Event[]  @relation("EventVendors")
  quotes       Quote[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Public partner-onboarding submissions (/partner-onboarding form).
// Kept SEPARATE from Vendor so spam/incomplete entries never pollute the vetted
// vendor list — founder reviews in /admin and approves → creates/merges Vendor.
// ── Contact fields here are PRIVATE, same rule as Vendor: never expose on
//    public routes/APIs/exports. POST is public (vendors submit their own info);
//    GET/PATCH are requireAdmin-only. ──
model VendorApplication {
  id              String   @id @default(uuid())
  appNumber       String   @unique // "SEM-P-0001" — sequential partner application number
  status          String   @default("Pending") // Pending, Approved, Rejected
  // Step 1 — company & contact
  companyName     String
  businessType    String?
  contactPerson   String
  jobTitle        String?
  whatsapp        String
  email           String?
  phone           String?
  city            String
  regionCoverage  String[] @default([])
  website         String?
  instagram       String?
  linkedin        String?
  facebook        String?
  tiktok          String?
  youtube         String?
  googleMaps      String?
  // Step 2 — services & company details
  categories      String[] @default([])
  servicesDesc    String?
  yearsInBusiness String?
  teamSize        String?
  languages       String?
  crNumber        String?
  vatNumber       String?
  // Step 3 — portfolio & pricing. LINKS ONLY (Drive/Dropbox/WeTransfer) —
  // event-industry files are too heavy for serverless upload; founder decision 2026-07.
  logoLink        String?
  profileLink     String?  // company profile PDF link
  portfolioLink   String?  // photos folder link
  videoLink       String?
  rateCardLink    String?
  pricingType     String?  // "Rate card" | "Project based"
  majorClients    String?
  certifications  String?
  // Step 4 — permissions & partnership (timestamped written consent record)
  permLogoUse     Boolean  @default(false)
  permMediaUse    Boolean  @default(false) // permission to use photos on SEM site + proposals
  permAccurate    Boolean  @default(false)
  // Non-circumvention consent (required): leads/inquiries via SEM remain SEM
  // property; no direct solicitation of SEM-introduced clients without written
  // SEM approval.
  permNonCircumvention Boolean @default(false)
  featureOnSem    Boolean  @default(false)
  backlinkAnswer  String?  // "Yes" | "Maybe later" | "No website"
  extraNotes      String?
  // review outcome — Approve adds to internal DB only; public site listing is a
  // separate later step (blocked until founder's SEO brief).
  vendorId        String?  // Vendor created or merged into on approval
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Append-only meeting/interaction log — never overwrite, always add a new row.
model VendorNote {
  id        String   @id @default(uuid())
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorId  String
  note      String
  createdAt DateTime @default(now())
}

model Quote {
  id          String   @id @default(uuid())
  amount      Float?
  details     String?
  status      String   @default("Pending") // Pending, Approved, Rejected
  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  vendorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inquiry {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  eventType   String?
  budget      String?
  eventDate   String?
  guestCount  String?
  venueCity   String?
  message     String
  status      String   @default("Pending") // Pending, Contacted, Confirmed, Cancelled
  assignedTo  String?  // Agent name or ID
  source      String?  @default("direct_contact")
  estimate    ClientEstimate?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  eventType   String?
  budget      String?
  eventDate   String?
  source      String?  @default("website") // website, referral, social, direct
  status      String   @default("New") // New, Contacted, Proposal Sent, Negotiation, Won, Lost
  notes       String?
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  content       String
  category      String?
  author        String?
  readTime      String?  @default("5 min read")
  metaTitle     String?
  metaDesc      String?
  seoScore      Int?     @default(0)
  publishedAt   DateTime?
  media         MediaAsset[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  quote     String
  author    String
  role      String?
  company   String?
  eventType String?
  photo     String?
  rating    Int      @default(5)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MediaAsset {
  id        String   @id @default(uuid())
  url       String
  type      String   @default("image") // image, video
  alt       String?
  event     Event?   @relation(fields: [eventId], references: [id])
  eventId   String?
  blogPost  BlogPost? @relation(fields: [blogPostId], references: [id])
  blogPostId String?
  createdAt DateTime @default(now())
}

model ClientEstimate {
  id          String   @id @default(uuid())
  baseAmount  Float
  serviceFee  Float
  totalAmount Float
  breakdown   String?  // JSON string of costs
  status      String   @default("Generated") // Generated, Sent, Accepted, Expired
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id])
  inquiryId   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // e.g., "Created Event", "Updated Quote"
  details   String?
  userEmail String?
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id           String   @id @default(uuid())
  clientName   String
  clientPhone  String
  clientEmail  String?
  eventType    String
  eventDate    DateTime?
  eventCity    String
  guestCount   Int?
  budgetRange  String?
  requirements String?
  source       String   @default("website")
  status       String   @default("pending") // pending | quote_sent | accepted | rejected | archived
  proposals    Proposal[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Proposal {
  id           String   @id @default(uuid())
  request      QuoteRequest @relation(fields: [requestId], references: [id])
  requestId    String
  quoteNumber  String   @unique // e.g. "SEM-Q-2025-001"
  lineItems    String   // JSON string of [{ service, description, qty, unitPrice, total }]
  subtotal     Float
  vatAmount    Float    // 15% VAT
  totalAmount  Float
  currency     String   @default("SAR")
  validUntil   DateTime
  notes        String?
  status       String   @default("draft") // draft | sent | accepted | rejected | expired
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FinancialRecord {
  id          String   @id @default(uuid())
  type        String   // revenue, expense, vendor_payment
  category    String?  // Event Revenue, Vendor Payment, Marketing, Operations
  amount      Float
  description String?
  reference   String?  // Event ID or Vendor ID
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Communication {
  id          String   @id @default(uuid())
  type        String   // whatsapp, email, sms, call, note
  direction   String   @default("outbound") // inbound, outbound
  subject     String?
  content     String?
  contactName String?
  contactRef  String?  // Client or Lead ID
  createdAt   DateTime @default(now())
}
